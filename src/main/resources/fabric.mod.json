{
	"schemaVersion": 1,
	"id": "${mod_id}",
	"version": "${mod_version}",
	"name": "${mod_name}",
	"description": "Adds Magic Carpets to Minecraft.",
	"authors": [
		"brainage04"
	],
	"contact": {
		"homepage": "https://github.com/brainage04/MagicCarpet",
		"sources": "https://github.com/brainage04/MagicCarpet"
	},
	"license": "MIT",
	"icon": "assets/magic_carpet/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"io.github.brainage04.magic_carpet.MagicCarpet"
		],
		"client": [
			"io.github.brainage04.magic_carpet.MagicCarpetClient"
		]
	},
	"mixins": [
		"magic_carpet.mixins.json"
	],
	"depends": {
		"fabricloader": ">=${loader_version}",
		"minecraft": "~${minecraft_version}",
		"java": ">=${java_version}",
		"fabric-api": "*"
